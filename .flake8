[flake8]
# Basic flake8 config for Python linting
max-line-length = 100
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    node_modules,
    .pytest_cache,
    .next
ignore =
    E203,  # whitespace before ':'
    W503,  # line break before binary operator
per-file-ignores =
    __init__.py:F401
