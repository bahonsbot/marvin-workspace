# Dedicated runtime env for isolated trading container
# Paper-only path. Do not put live trading endpoints here.

APP_ENV=production
PAPER_MODE=true
PAPER_EXECUTE=false

# Safety toggles
KILL_SWITCH=true
DAILY_LOSS_CAP=100.0
MAX_POSITION_SIZE=1
MAX_OPEN_POSITIONS=3

# Webhook runtime
# Default safe shadow mode keeps localhost binding. Set ALLOW_CONTAINER_BIND=true
# only when validating host-published ingress for the isolated trading container.
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8000
ALLOW_CONTAINER_BIND=false
WEBHOOK_SHARED_SECRET=REPLACE_WITH_STRONG_SECRET
AUTO_WEBHOOK_URL=http://127.0.0.1:18000/webhook

# Broker (paper only)
ALPACA_API_KEY=REPLACE_WITH_YOUR_PAPER_API_KEY
ALPACA_API_SECRET=REPLACE_WITH_YOUR_PAPER_SECRET_KEY
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Trading automation controls
EXECUTION_CANDIDATES_ENABLED=true
AUTO_MIN_CONFIDENCE="STRONG BUY"
AUTO_MIN_REASONING_SCORE=80
AUTO_BASE_QTY=1
AUTO_MAX_QTY=1
AUTO_MARKET_HOURS_ONLY=true
AUTO_FAST_REGIME_ENABLED=true
AUTO_FAST_MIN_REASONING_SCORE=75
AUTO_FAST_QTY_MULTIPLIER=1.25
AUTO_FAST_GEO_THRESHOLD=3
AUTO_FAST_HIGH_CONF_THRESHOLD=30

# Notifications
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_TELEGRAM_CHAT_ID
TELEGRAM_PHILIPPE_CHAT_ID=REPLACE_WITH_TELEGRAM_PHILIPPE_CHAT_ID
