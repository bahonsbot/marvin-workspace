# Paper-only development environment
# Do not put real API keys in this project during foundation phase.

APP_ENV=development
PAPER_MODE=true
PAPER_EXECUTE=false

# Safety toggles
KILL_SWITCH=true

# Risk defaults (example values)
DAILY_LOSS_CAP=100.0
MAX_POSITION_SIZE=1
MAX_OPEN_POSITIONS=3

# Placeholder values only (not used in foundation)
ALPACA_API_KEY=REPLACE_WITH_YOUR_PAPER_API_KEY
ALPACA_API_SECRET=REPLACE_WITH_YOUR_PAPER_SECRET_KEY
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
AUTO_WEBHOOK_URL=http://127.0.0.1:8000/webhook
AUTO_MIN_CONFIDENCE="STRONG BUY"
AUTO_MIN_REASONING_SCORE=80
AUTO_BASE_QTY=1
AUTO_MAX_QTY=1
AUTO_MARKET_HOURS_ONLY=true
WEBHOOK_SHARED_SECRET=change-me
AUTO_FAST_REGIME_ENABLED=true
AUTO_FAST_MIN_REASONING_SCORE=75
AUTO_FAST_QTY_MULTIPLIER=1.25
AUTO_FAST_GEO_THRESHOLD=3
AUTO_FAST_HIGH_CONF_THRESHOLD=30
