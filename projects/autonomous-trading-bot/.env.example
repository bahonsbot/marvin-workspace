# Paper-only development environment
# Do not put real API keys in this project during foundation phase.

APP_ENV=development
PAPER_MODE=true

# Safety toggles
KILL_SWITCH=true

# Risk defaults (example values)
DAILY_LOSS_CAP=100.0
MAX_POSITION_SIZE=1
MAX_OPEN_POSITIONS=3

# Placeholder values only (not used in foundation)
ALPACA_API_KEY=REPLACE_WITH_PAPER_KEY_ONLY
ALPACA_API_SECRET=REPLACE_WITH_PAPER_SECRET_ONLY
ALPACA_BASE_URL=https://paper-api.alpaca.markets
