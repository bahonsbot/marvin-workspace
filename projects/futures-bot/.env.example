# Futures Broker (Tradovate)
TRADOVATE_API_KEY=
TRADOVATE_API_SECRET=
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_CID=
TRADOVATE_BASE_URL=https://demo.tradovateapi.com

# Safety defaults (paper-only)
PAPER_MODE=true
KILL_SWITCH=true
DAILY_LOSS_CAP=500.0
MAX_CONTRACTS_PER_SIGNAL=1
MAX_OPEN_POSITIONS=3
MARGIN_WARNING_THRESHOLD=0.30
MARGIN_HARD_CAP=0.50

# Market hours gate
MARKET_HOURS_ONLY=true
ALLOW_OVERNIGHT=false

# Webhook settings
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8001
WEBHOOK_SHARED_SECRET=
AUTO_WEBHOOK_URL=http://127.0.0.1:8001/webhook

# Dispatch filters
AUTO_MIN_CONFIDENCE=STRONG BUY
AUTO_MIN_REASONING_SCORE=85

# Logging
WEBHOOK_LOG_PATH=logs/webhook_decisions.jsonl
