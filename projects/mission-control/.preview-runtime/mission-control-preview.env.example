# Copy this file to:
# /data/.openclaw/workspace/projects/mission-control/.preview-runtime/mission-control-preview.env
# Then replace the placeholder values and restart the Mission Control preview.

MISSION_CONTROL_BASIC_AUTH_USER=change-me
MISSION_CONTROL_BASIC_AUTH_PASS=change-me-please-use-a-strong-password

# Optional WS sidecar overrides.
# The preview start script generates MISSION_CONTROL_WS_SIDECAR_TOKEN automatically.
MISSION_CONTROL_WS_SIDECAR_HOST=127.0.0.1
MISSION_CONTROL_WS_SIDECAR_PORT=3006
MISSION_CONTROL_WS_SIDECAR_PATH=/mission-control-runtime
MISSION_CONTROL_WS_PUBLIC_PATH=/api/runtime-bridge/ws
# Optional override if the preview is behind a separate external reverse proxy.
# MISSION_CONTROL_WS_SIDECAR_PUBLIC_URL=wss://your-preview-host/api/runtime-bridge/ws

# Optional real gateway session auth for browser-side connect.challenge -> connect.
# Leave unset to keep Mission Control in transport-only mode.
# MISSION_CONTROL_GATEWAY_AUTH_TOKEN=replace-with-a-real-gateway-auth-token

# Enable live-source research packets for autonomous tasks.
# Supported providers: DuckDuckGo HTML (`duckduckgo-html`) and SearXNG (`searxng`).
# Set both server and NEXT_PUBLIC variants so browser-side preflight matches runtime truth.
# MISSION_CONTROL_WEB_RESEARCH_ENABLED=1
# MISSION_CONTROL_SEARCH_PROVIDER=searxng
# MISSION_CONTROL_SEARXNG_BASE_URL=http://72.60.232.55:32768
# NEXT_PUBLIC_MISSION_CONTROL_WEB_RESEARCH_ENABLED=1
# NEXT_PUBLIC_MISSION_CONTROL_SEARCH_PROVIDER=searxng

# Phase-1 speech-to-text transcription for Mission Control Chat.
# Preferred local path, matching Nerve's posture more closely:
# MISSION_CONTROL_TRANSCRIBE_PROVIDER=local
# MISSION_CONTROL_WHISPER_MODEL=base.en
# MISSION_CONTROL_WHISPER_MODEL_DIR=~/.nerve/models
# MISSION_CONTROL_TRANSCRIBE_LANGUAGE=en
#
# OpenAI fallback path:
# MISSION_CONTROL_TRANSCRIBE_PROVIDER=openai
# MISSION_CONTROL_TRANSCRIBE_API_KEY=<your_openai_api_key>
# MISSION_CONTROL_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# MISSION_CONTROL_TRANSCRIBE_BASE_URL=https://api.openai.com/v1
# MISSION_CONTROL_TRANSCRIBE_TIMEOUT_MS=45000

# Explicit Origin header for the sidecar -> gateway websocket hop.
MISSION_CONTROL_WS_UPSTREAM_ORIGIN=https://preview.motiondisplay.cloud
