# Ignore these (sensitive/workspace)
*.md
backup/
memory/*
.openclaw/
**/node_modules/
**/.next/
**/__pycache__/
*.pyc
*.bak
projects/mission-control/.preview-runtime/*
!projects/mission-control/.preview-runtime/mission-control-preview.env.example
projects/mission-control/tsconfig.tsbuildinfo
projects/mission-control/data/task-lifecycle-events.json
projects/mission-control/.test-dist/
projects/market-intel/data/last_signal_check
projects/market-intel/data/rss_alerts.json
projects/market-intel/data/reddit_alerts.json
projects/market-intel/data/signals.json
projects/market-intel/data/enhanced_signals.json
projects/market-intel/data/signal_state.json
projects/autonomous-trading-bot/data/state/auto_signal_dispatch.json
projects/autonomous-trading-bot/data/state/idempotency.json
memory/2026-03-25.md
auth.json
config/token-manifest.json
*.json.bak*
*.json.bak

# Keep these (exceptions must come AFTER the patterns they override)
!*.gitignore
!SUBAGENT-POLICY.md
!AUTONOMOUS.md
!memory/tasks-log.md
*.py

# Runtime logs (sensitive - may contain payloads)
**/logs/*.jsonl
**/logs/*.log
blender-test/
.env

# Environment secrets
**/.env

# Mission Control lab runtime snapshot generated state
projects/mission-control-lab/.lab-runtime/*
!projects/mission-control-lab/.lab-runtime/.gitkeep
projects/mission-control-lab/mission-control-preview.log
projects/mission-control-lab/data/skills-summary-cache.json

# Mission Control physical lab runtime snapshot; source truth lives in projects/mission-control until converted to a worktree
projects/mission-control-lab/**
!projects/mission-control-lab/
!projects/mission-control-lab/scripts/
!projects/mission-control-lab/scripts/mission-control-service-run.sh

# Mission Control runtime UI state. Source code owns schemas/adapters; live JSON stays on disk.
projects/mission-control/data/*.json
!projects/mission-control/data/.gitkeep
